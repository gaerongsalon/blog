{
  "name": "@blog/pages",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "postbuild": "rm -rf ../api/pages && cp -r dist ../api/pages",
