    "date-fns": "^4.1.0",
    "ismobilejs": "^1.1.1",
    "quill-delta": "^5.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-dropzone": "^15.0.0",
    "react-helmet-async": "^3.0.0",
    "react-quill-new": "^3.8.3",
    "react-router-dom": "^7.14.2",
    "react-spinners": "^0.17.0",
    "styled-components": "^6.4.1",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
